<div class="page-container">
  <article class="page-content">
    <% if (page.title) { %>
      <header class="page-header">
        <h1 class="page-title"><%= page.title %></h1>
        <% if (page.subtitle) { %>
          <p class="page-subtitle"><%= page.subtitle %></p>
        <% } %>
      </header>
    <% } %>

    <div class="page-body">
      <%- page.content %>
    </div>
  </article>
</div>
