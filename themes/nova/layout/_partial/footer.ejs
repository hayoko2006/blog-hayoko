<footer class="nova-footer">
  <div class="footer-container">
    <div class="footer-content">
      <div class="footer-brand">
        <a href="<%= url_for('/') %>" class="footer-brand-link">
          <i class="fas fa-star"></i>
          <span><%= config.title %></span>
        </a>
        <p class="footer-description"><%= config.description || '' %></p>
      </div>

      <div class="footer-links">
        <div class="footer-links-group">
          <h4 class="footer-links-title">Navigation</h4>
          <nav class="footer-nav">
            <% for (const [label, path] of Object.entries(theme.nav || {})) { %>
              <a href="<%= url_for(path) %>"><%= label %></a>
            <% } %>
          </nav>
        </div>

        <% if (theme.sidebar && theme.sidebar.social) { %>
        <div class="footer-links-group">
          <h4 class="footer-links-title">Connect</h4>
          <div class="footer-social">
            <% if (theme.sidebar.social.github) { %>
              <a href="<%= theme.sidebar.social.github %>" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                <i class="fab fa-github"></i>
              </a>
            <% } %>
            <% if (theme.sidebar.social.twitter) { %>
              <a href="<%= theme.sidebar.social.twitter %>" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                <i class="fab fa-twitter"></i>
              </a>
            <% } %>
            <% if (theme.sidebar.social.email) { %>
              <a href="mailto:<%= theme.sidebar.social.email %>" aria-label="Email">
                <i class="fas fa-envelope"></i>
              </a>
            <% } %>
          </div>
        </div>
        <% } %>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-copyright">
        &copy; <%= theme.footer && theme.footer.since || new Date().getFullYear() %> - <%= new Date().getFullYear() %>
        <a href="<%= url_for('/') %>"><%= config.author || config.title %></a>
        <% if (theme.footer && theme.footer.icp) { %>
          <span class="footer-icp"><%= theme.footer.icp %></span>
        <% } %>
      </div>
      <div class="footer-powered">
        Powered by <a href="https://hexo.io/" target="_blank" rel="noopener noreferrer">Hexo</a>
        &amp; Theme <a href="#">Nova</a>
      </div>
      <% if (theme.footer && theme.footer.custom_text) { %>
        <div class="footer-custom"><%= theme.footer.custom_text %></div>
      <% } %>
    </div>
  </div>

  <!-- Back to Top -->
  <button class="back-to-top" id="back-to-top" aria-label="Back to top">
    <i class="fas fa-arrow-up"></i>
  </button>
</footer>
